# Database
DATABASE_URL=postgresql://oikos:changeme@db:5432/oikos
POSTGRES_USER=oikos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oikos

# Auth
APP_PASSWORD=changeme
JWT_SECRET=changeme-use-a-long-random-string

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# Claude CLI (path inside the container)
CLAUDE_BIN=/usr/local/bin/claude

# Pantry
EXPIRY_WARN_DAYS=7
